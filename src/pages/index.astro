---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Clock from "../components/Clock";
import DateDisplay from "../components/Date";
import ConnectionStatus from "../components/ConnectionStatus";
import Quotable from "../components/Quotable";
---

<Layout>
  <main class="grid h-svh grid-rows-[2fr_1fr] overflow-hidden p-0 text-center">
    <div class="grid min-h-0 grid-rows-2">
      <div
        class="@container relative [--bg-color:color-mix(in_srgb,#5b9ea8_15%,black)] bg-[var(--bg-color)] text-[#7ebdc8] px-[1cqw] py-0 flex justify-center items-center flex-col min-h-0 min-w-0 overflow-hidden [container-type:size]"
      >
        <div class="absolute top-0 left-0">
          <ConnectionStatus client:load />
        </div>
        <div class="relative w-full">
          <div
            class="absolute left-0 right-0 bottom-full mb-[1.5cqh] text-[clamp(16px,min(5.5cqw,14cqh),96px)]"
          >
            <DateDisplay client:load />
          </div>
          <Clock client:load />
        </div>
      </div>
      <div
        class="@container px-[1cqw] py-[1.5cqh] relative [--bg-color:color-mix(in_srgb,var(--color-purple-500)_15%,black)] bg-[var(--bg-color)] text-purple-500 font-normal flex leading-[100%] items-center justify-center min-h-0 min-w-0 overflow-hidden [container-type:size] text-[clamp(12px,min(3.5cqw,10cqh),48px)]"
      >
        <Quotable client:load />
      </div>
    </div>
    <iframe
      src="https://steps.chasecee.com"
      title="Steps"
      class="min-h-0 h-full w-full border-0"
      loading="lazy"
    ></iframe>
  </main>
</Layout>
