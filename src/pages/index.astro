---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
import Clock from "../components/Clock";
import DateDisplay from "../components/Date";
import ConnectionStatus from "../components/ConnectionStatus";
import Quotable from "../components/Quotable";
import StepsChart from "../components/StepsChart";
---

<Layout>
  <main
    class="flex flex-nowrap h-svh overflow-hidden flex-col items-stretch justify-center p-0 text-center"
  >
    <div class="flex flex-row flex-[2] min-h-0">
      <div
        class="@container relative bg-[#bdb76b]/10 text-[#bdb76b] px-[1cqw] py-0 flex justify-center items-center flex-col flex-1 min-h-0 min-w-0 overflow-hidden [container-type:size]"
      >
        <div class="absolute top-0 left-0">
          <ConnectionStatus client:load />
        </div>
        <div class="text-[clamp(20px,min(7cqw,18cqh),120px)]">
          <DateDisplay client:load />
        </div>
        <Clock client:load />
      </div>

      <div
        class="@container px-[1cqw] py-[1.5cqh] relative bg-purple-500/10 text-purple-500 font-normal flex flex-1 leading-[100%] items-center justify-center min-h-0 min-w-0 overflow-hidden [container-type:size] text-[clamp(12px,min(3.5cqw,10cqh),48px)]"
      >
        <Quotable client:load />
      </div>
    </div>

    <div class="flex flex-row flex-1 min-h-0">
      <StepsChart client:load />
    </div>
  </main>
</Layout>
